# GOrchestrator Configuration
# Copy this file to .env and update values as needed.
#
# LiteLLM-based routing: Claude models automatically use Anthropic native API,
# OpenAI/other models use OpenAI-compatible API. No manual provider config needed.
# Both Manager and Worker use the same LiteLLM library with custom_llm_provider.

# ============================================================
# MANAGER (Orchestrator Agent) Configuration
# The Manager is the intelligent LLM that talks to you and
# decides when to delegate tasks to Worker agents.
# ============================================================

# Manager Profile System (NEW)
# If set, loads manager config from src/core/manager_profiles/<MANAGER_PROFILE>.yaml
# If not set or file doesn't exist, falls back to ORCHESTRATOR_* variables below
# Profiles: default, advanced, minimal, custom (see src/core/manager_profiles/)
MANAGER_PROFILE=default

# Manager Rules File (NEW)
# Rules configuration file in manager_profiles directory
# Controls manager behavior: delegation, response format, quality checks
MANAGER_RULES_FILE=rules.yaml

# Legacy Manager Config (backward compatible, used only if MANAGER_PROFILE not set)
# LLM model for the Manager Agent
# Supported: claude-*, gpt-*, o1-*, gemini-*, deepseek-*, etc.
ORCHESTRATOR_MODEL=claude-sonnet-4-20250514

# API endpoint (Antigravity Manager proxy)
ORCHESTRATOR_API_BASE=http://127.0.0.1:8045

# API key for the proxy
ORCHESTRATOR_API_KEY=sk-your-proxy-key

# ============================================================
# WORKER (Integrated Worker Core) Configuration
# The default Worker is the coding agent that executes tasks.
# Additional workers can be added at runtime with /worker add.
# ============================================================

# Default Worker model
WORKER_MODEL=claude-sonnet-4-20250514

# Configuration profile for the Worker agent
# Profiles are YAML files in src/worker_core/.miniswe/configs/
#   - 'livesweagent': SWE agent with specialized prompts (default)
#   - 'live': Standard production mode
#   - Custom profiles you create
WORKER_PROFILE=livesweagent

# Path to worker core (integrated, usually no need to change)
AGENT_PATH=src/worker_core

# Proxy configuration for Worker subprocess
PROXY_URL=http://127.0.0.1:8045
PROXY_KEY=sk-your-proxy-key

# ============================================================
# Application Settings
# ============================================================

# Show detailed Worker output (true/false)
VERBOSE_WORKER=false

# Maximum Worker retry iterations per task
MAX_WORKER_ITERATIONS=5

# Maximum time in seconds for a Worker task before timeout (0 = no timeout)
WORKER_TIMEOUT=600

# ============================================================
# Notes
# ============================================================
# - Manager: Single instance, use /manager commands to configure
# - Workers: Multi-instance, use /worker commands to manage
# - Both support runtime configuration changes via slash commands
# - Runtime overrides (via /manager, /config set) are persisted to .env
# - Profile-based configuration (.yaml files) for both Manager and Workers
# - LiteLLM provider routing for both Manager and Workers
# - Per-worker API endpoints: /worker api <name> <url> [key]
# - Multi-worker: /worker add <name> [model] [profile]
# - Config changes at runtime: /model, /config set
# - All runtime config changes are persisted to this file
